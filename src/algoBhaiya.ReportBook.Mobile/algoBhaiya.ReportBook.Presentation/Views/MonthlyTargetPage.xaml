<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:algoBhaiya.ReportBook.Presentation.ViewModels"
             x:Class="algoBhaiya.ReportBook.Presentation.Views.MonthlyTargetPage"
             Title="Set Monthly Targets">

    <Grid Padding="10" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Search Row -->
        <HorizontalStackLayout Grid.Row="0"
                               Spacing="10"
                               VerticalOptions="Center"
                               HorizontalOptions="Center">
            <!-- Filter Buttons Row -->
            <Button Text="🗓️ By Month"
                    FontAttributes="Bold"
                    Clicked="OnMonthCalendarClicked"
                    BackgroundColor="#f0f0f0"
                    TextColor="Black"
                    CornerRadius="20"
                    Padding="10,5"
                    FontSize="14"
                    MaximumHeightRequest="50" />

            <Frame CornerRadius="12"
                   BackgroundColor="#E0F2F1"
                   BorderColor="#4CAF50"
                   Padding="13"
                   HasShadow="False"
                   Margin="0,5,0,5">
                <HorizontalStackLayout Spacing="5"
                                       VerticalOptions="Center"
                                       HorizontalOptions="CenterAndExpand">
                    <Label Text="Month:"
                           FontAttributes="Italic"
                           FontSize="13"
                           VerticalOptions="Center"
                           TextColor="#2E7D32" />
                    <Label Text="{Binding CurrentMonthLabel}"
                           FontAttributes="Bold"
                           FontSize="15"
                           TextColor="#1B5E20"
                           Padding="1,4" />
                </HorizontalStackLayout>
            </Frame>
        </HorizontalStackLayout>

        <!-- Data List -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Fields}"
                        VerticalOptions="FillAndExpand">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnSpacing="10" Padding="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="5*" />
                            <!-- FieldName: 50% -->
                            <ColumnDefinition Width="3*" />
                            <!-- Input: 30% -->
                            <ColumnDefinition Width="2*" />
                            <!-- Unit: 20% -->
                        </Grid.ColumnDefinitions>

                        <!-- Field Name -->
                        <Label Grid.Column="0"
                               Text="{Binding FieldName}"
                               FontAttributes="Bold"
                               VerticalOptions="Center" />

                        <!-- Input -->
                        <StackLayout Grid.Column="1" VerticalOptions="Center">
                            <Entry Placeholder="Enter value"
                                   Keyboard="Numeric"
                                   HorizontalTextAlignment="Center"
                                   Text="{Binding TargetValue}" />
                        </StackLayout>

                        <!-- Unit -->
                        <Label Grid.Column="2"
                               Text="{Binding UnitName}"
                               FontAttributes="Italic"
                               TextColor="Gray"
                               VerticalOptions="Center"
                               HorizontalTextAlignment="Start" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.EmptyView>
                <StackLayout Padding="20"
                             HorizontalOptions="Center"
                             VerticalOptions="Center">
                    <Label Text="No records found for this month."
                           TextColor="Gray"
                           FontAttributes="Italic"
                           FontSize="15" />
                </StackLayout>
            </CollectionView.EmptyView>
        </CollectionView>

        <!-- Submit -->
        <VerticalStackLayout Grid.Row="2" Spacing="8">
            <Button Text="Save Targets"
                    Command="{Binding SubmitCommand}"
                    IsEnabled="{Binding CanSubmit}"
                    IsVisible="{Binding CanSubmit}"
                    BackgroundColor="#4CAF50"
                    TextColor="White" />

            <Label Text="No modification for previous month."   
                   HorizontalOptions="Center"
                   TextColor="Red"
                   FontAttributes="Italic"
                   FontSize="12"
                   IsVisible="{Binding IsReadOnly}" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>
