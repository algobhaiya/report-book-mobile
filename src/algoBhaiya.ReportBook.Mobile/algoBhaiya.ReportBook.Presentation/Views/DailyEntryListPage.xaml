<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:algoBhaiya.ReportBook.Presentation.Views"
             x:Class="algoBhaiya.ReportBook.Presentation.Views.DailyEntryListPage"
             Title="{Binding SelectedMonthLabel}">
    <Grid RowDefinitions="Auto,*" Padding="10">
        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Spacing="10" Padding="0,5">

            <!-- Search Row -->
            <HorizontalStackLayout Spacing="10" VerticalOptions="Center" HorizontalOptions="FillAndExpand">
                <Label Text="Search"
                       FontAttributes="Italic"
                       FontSize="15"
                       VerticalOptions="Center" />

                <!-- (Optional: Replace with SearchBar or Entry if you want text input in future) -->
                <!-- <SearchBar Placeholder="Enter keyword..." /> -->
            </HorizontalStackLayout>

            <!-- Filter Buttons Row -->
            <HorizontalStackLayout Spacing="4"
                                   HorizontalOptions="Center">
                <Button Text="📍 Today"
                        FontAttributes="Bold"
                        Clicked="OnTodayCalendarClicked"
                        BackgroundColor="#f0f0f0"
                        TextColor="Black"
                        CornerRadius="20"
                        Padding="10,5"
                        FontSize="14" />
                
                <Button Text="📅 By Date"
                        FontAttributes="Bold"
                        Clicked="OnDateCalendarClicked"
                        BackgroundColor="#f0f0f0"
                        TextColor="Black"
                        CornerRadius="20"
                        Padding="10,5"
                        FontSize="14" />

                <Button Text="🗓️ By Month"
                        FontAttributes="Bold"
                        Clicked="OnMonthCalendarClicked"
                        BackgroundColor="#f0f0f0"
                        TextColor="Black"
                        CornerRadius="20"
                        Padding="10,5"
                        FontSize="14" />

                <!-- Refresh Button -->
                <Button Text="🔄"
                        FontAttributes="Bold"
                        Clicked="OnRefreshClicked"
                        BackgroundColor="#e0f7fa"
                        TextColor="Black"
                        CornerRadius="20"
                        Padding="10,5"
                        FontSize="14"
                        HorizontalOptions="EndAndExpand" />
                
            </HorizontalStackLayout>
        </VerticalStackLayout>

        <!-- Scrollable Daily Records -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding DailySummaries}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Stroke="{Binding StatusBadgeBorderColor}"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#111827}"
                            StrokeThickness="1.5"
                            StrokeShape="RoundRectangle 16"
                            Margin="5"
                            Padding="14,12">
                        <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding DateString}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#1F2937, Dark=#F9FAFB}"/>
                                <Label Text="{Binding StatusText}"
                                       FontSize="13"
                                       TextColor="{AppThemeBinding Light=#6B7280, Dark=#D1D5DB}"/>
                                <Label Text="{Binding StatusSupportText}"
                                       FontSize="12"
                                       LineBreakMode="TailTruncation"
                                       TextColor="{AppThemeBinding Light=#9CA3AF, Dark=#9CA3AF}"/>
                            </VerticalStackLayout>

                            <Border Grid.Column="1"
                                    BackgroundColor="{Binding StatusBadgeBackgroundColor}"
                                    Stroke="{Binding StatusBadgeBorderColor}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 999"
                                    Padding="12,7"
                                    VerticalOptions="Center">
                                <HorizontalStackLayout Spacing="8"
                                                       VerticalOptions="Center"
                                                       HorizontalOptions="Center">
                                    <Image Source="{Binding StatusIcon}"
                                           HeightRequest="18"
                                           WidthRequest="18"
                                           Aspect="AspectFit"/>
                                    <Label Text="{Binding StatusBadgeText}"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           TextColor="{Binding StatusBadgeTextColor}"
                                           VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                            </Border>
                        </Grid>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type local:DailyEntryListPage}}, Path=BindingContext.OpenEntryCommand}"
                                                  CommandParameter="{Binding .}"/>
                        </Border.GestureRecognizers>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.EmptyView>
                <StackLayout Padding="20" HorizontalOptions="Center" VerticalOptions="Center">
                    <Label Text="No records found for this month." 
                           TextColor="Gray" 
                           FontAttributes="Italic" 
                           FontSize="15"/>
                </StackLayout>
            </CollectionView.EmptyView>
        </CollectionView>

    </Grid>
</ContentPage>
