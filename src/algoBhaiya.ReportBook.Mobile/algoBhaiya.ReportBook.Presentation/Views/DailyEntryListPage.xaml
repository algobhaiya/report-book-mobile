<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:algoBhaiya.ReportBook.Presentation.Views"
             x:Class="algoBhaiya.ReportBook.Presentation.Views.DailyEntryListPage"
             Title="{Binding SelectedMonthLabel}">
    <Grid RowDefinitions="Auto,*" Padding="10">
        <VerticalStackLayout Grid.Row="0" Spacing="10" Padding="0,5">

            <HorizontalStackLayout Spacing="4"
                                   HorizontalOptions="Center">
                <Button Text="📍 Today"
                        FontAttributes="Bold"
                        Clicked="OnTodayCalendarClicked"
                        BackgroundColor="#f0f0f0"
                        TextColor="Black"
                        CornerRadius="20"
                        Padding="10,5"
                        FontSize="14" />

                <Button Text="📅 By Date"
                        FontAttributes="Bold"
                        Clicked="OnDateCalendarClicked"
                        BackgroundColor="#f0f0f0"
                        TextColor="Black"
                        CornerRadius="20"
                        Padding="10,5"
                        FontSize="14" />

                <Button Text="🗓️ By Month"
                        FontAttributes="Bold"
                        Clicked="OnMonthCalendarClicked"
                        BackgroundColor="#f0f0f0"
                        TextColor="Black"
                        CornerRadius="20"
                        Padding="10,5"
                        FontSize="14" />

                <!-- Refresh Button -->
                <Button Text="🔄"
                        FontAttributes="Bold"
                        Clicked="OnRefreshClicked"
                        BackgroundColor="#e0f7fa"
                        TextColor="Black"
                        CornerRadius="20"
                        Padding="10,5"
                        FontSize="14"
                        HorizontalOptions="EndAndExpand" />
            </HorizontalStackLayout>

        </VerticalStackLayout>

        <RefreshView Grid.Row="1"
                     IsRefreshing="{Binding IsRefreshing, Mode=TwoWay}"
                     Command="{Binding RefreshCommand}">
            <CollectionView ItemsSource="{Binding DailySummaries}"
                            Margin="0,8,0,0">
            <CollectionView.Header>
                <Border BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#111827}"
                        Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#1F2937}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 20"
                        Padding="14"
                        Margin="0,0,0,10">
                    <Grid RowDefinitions="Auto,Auto"
                          ColumnDefinitions="*,Auto"
                          ColumnSpacing="10"
                          RowSpacing="10">
                        <VerticalStackLayout Spacing="10"
                                             VerticalOptions="Center"
                                             Grid.ColumnSpan="2">
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="10"
                                  VerticalOptions="Center">
                                <Label Text="{Binding SelectedMonthLabel}"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}" />

                                <Border Grid.Column="1"
                                        BackgroundColor="{AppThemeBinding Light=#E8F5E9, Dark=#1F2937}"
                                        Stroke="{AppThemeBinding Light=#A5D6A7, Dark=#374151}"
                                        StrokeThickness="1.5"
                                        StrokeShape="RoundRectangle 4"
                                        Padding="4"
                                        VerticalOptions="Center">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnMonthlySummaryClicked" />
                                    </Border.GestureRecognizers>

                                    <Label Text="📊"
                                           FontSize="18"
                                           VerticalOptions="Center"
                                           HorizontalOptions="Center"
                                           TextColor="{AppThemeBinding Light=#1B5E20, Dark=#F9FAFB}" />
                                </Border>
                            </Grid>

                            <HorizontalStackLayout Spacing="8"
                                                   HorizontalOptions="Start">
                                <Border IsVisible="{Binding HasCompletedDays}"
                                        BackgroundColor="#E8F5E9"
                                        Stroke="#43A047"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 999"
                                        Padding="10,5">
                                    <Label Text="{Binding CompletedDaysText}"
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           TextColor="#1B5E20" />
                                </Border>

                                <Border IsVisible="{Binding HasIncompleteDays}"
                                        BackgroundColor="#EEF6FF"
                                        Stroke="#8CBFEA"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 999"
                                        Padding="10,5">
                                    <Label Text="{Binding IncompleteDaysText}"
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           TextColor="#2A6DB0" />
                                </Border>

                                <Border IsVisible="{Binding HasPendingDays}"
                                        BackgroundColor="#FFF8E1"
                                        Stroke="#F9A825"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 999"
                                        Padding="10,5">
                                    <Label Text="{Binding PendingDaysText}"
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           TextColor="#7A5A00" />
                                </Border>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>

                        <Grid Grid.Row="1"
                              Grid.ColumnSpan="2"
                              ColumnDefinitions="*,Auto"
                              ColumnSpacing="12"
                              VerticalOptions="Center"
                              IsVisible="{Binding IsCurrentMonth}">
                            <VerticalStackLayout Spacing="6"
                                                 VerticalOptions="Center">
                                <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center" ColumnSpacing="10">
                                    <Label Text="{Binding TodayStatusText}"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           LineBreakMode="TailTruncation"
                                           TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" />
                                    <Label Grid.Column="1"
                                           Text="{Binding TodayProgressPercentText}"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           TextColor="{Binding TodayProgressColor}"
                                           HorizontalTextAlignment="End"
                                           VerticalOptions="Center" />
                                </Grid>

                                <ProgressBar Progress="{Binding TodayProgressRatio}"
                                             ProgressColor="{Binding TodayProgressColor}"
                                             BackgroundColor="{Binding TodayTrackColor}"
                                             HeightRequest="6" />

                                <Label Text="{Binding TodayStatusSupportText}"
                                       FontSize="11"
                                       LineBreakMode="TailTruncation"
                                       TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" />
                            </VerticalStackLayout>

                            <Border Grid.Column="1"
                                    BackgroundColor="{AppThemeBinding Light=#111827, Dark=#E5E7EB}"
                                    Stroke="{AppThemeBinding Light=#111827, Dark=#E5E7EB}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 999"
                                    Padding="10,7"
                                    HorizontalOptions="End"
                                    VerticalOptions="Center">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnTodayCalendarClicked" />
                                </Border.GestureRecognizers>

                                <HorizontalStackLayout Spacing="6"
                                                       VerticalOptions="Center"
                                                       HorizontalOptions="Center">
                                    <Border BackgroundColor="{AppThemeBinding Light=White, Dark=#111827}"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 999"
                                            Padding="4"
                                            VerticalOptions="Center">
                                        <Label Text="&#x2197;"
                                               FontSize="14"
                                               FontAttributes="Bold"
                                               HorizontalTextAlignment="Center"
                                               VerticalTextAlignment="Center"
                                               TextColor="{AppThemeBinding Light=#111827, Dark=#E5E7EB}" />
                                    </Border>

                                    <Label Text="Open"
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           VerticalOptions="Center"
                                           TextColor="{AppThemeBinding Light=White, Dark=#111827}" />
                                </HorizontalStackLayout>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </CollectionView.Header>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Stroke="{Binding StatusBadgeBorderColor}"
                            BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#111827}"
                            StrokeThickness="1.5"
                            StrokeShape="RoundRectangle 16"
                            Margin="5"
                            Padding="14,12">
                        <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding DateString}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#1F2937, Dark=#F9FAFB}" />
                                <Label Text="{Binding StatusText}"
                                       FontSize="13"
                                       TextColor="{AppThemeBinding Light=#6B7280, Dark=#D1D5DB}" />
                            </VerticalStackLayout>

                            <Border Grid.Column="1"
                                    BackgroundColor="{Binding StatusBadgeBackgroundColor}"
                                    Stroke="{Binding StatusBadgeBorderColor}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 999"
                                    Padding="12,7"
                                    VerticalOptions="Center">
                                <HorizontalStackLayout Spacing="8"
                                                       VerticalOptions="Center"
                                                       HorizontalOptions="Center">
                                    <Image Source="{Binding StatusIcon}"
                                           HeightRequest="18"
                                           WidthRequest="18"
                                           Aspect="AspectFit" />
                                    <Label Text="{Binding StatusBadgeText}"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           TextColor="{Binding StatusBadgeTextColor}"
                                           VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </Border>
                        </Grid>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type local:DailyEntryListPage}}, Path=BindingContext.OpenEntryCommand}"
                                                  CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.EmptyView>
                <StackLayout Padding="20"
                             HorizontalOptions="Center"
                             VerticalOptions="Center">
                    <Label Text="No records found for this month."
                           TextColor="Gray"
                           FontAttributes="Italic"
                           FontSize="15" />
                </StackLayout>
            </CollectionView.EmptyView>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
