<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:algoBhaiya.ReportBook.Presentation.Views;assembly=algoBhaiya.ReportBook.Presentation"
             xmlns:local="clr-namespace:algoBhaiya.ReportBook.Presentation.Views"
             x:Class="algoBhaiya.ReportBook.Presentation.Views.LoginPage"
             BackgroundColor="{AppThemeBinding Light=#F7F8FC, Dark=#111418}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <local:UserInitialsConverter x:Key="UserInitialsConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="20,24" Spacing="18">
            <Border StrokeShape="RoundRectangle 28"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#20242B}"
                    Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#3A414C}"
                    Padding="22">
                <Grid RowDefinitions="Auto,Auto" RowSpacing="12">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                        <Border WidthRequest="56"
                                HeightRequest="56"
                                StrokeShape="RoundRectangle 28"
                                BackgroundColor="{AppThemeBinding Light=#DBEAFE, Dark=#31415A}"
                                StrokeThickness="0">
                            <Image Source="book_solid.svg"
                                   WidthRequest="28"
                                   HeightRequest="28"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   Aspect="AspectFit" />
                        </Border>

                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Report Book!"
                                   FontSize="28"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#111827, Dark=White}" />
                            <Label Text="Track your habits."
                                   FontSize="13"
                                   TextColor="{AppThemeBinding Light=#4B5563, Dark=#B3BBC7}" />
                        </VerticalStackLayout>
                    </Grid>

                    <Border Grid.Row="1"
                            StrokeShape="RoundRectangle 16"
                            BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#252B33}"
                            Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#3E4652}"
                            Padding="12,10">
                        <Label Text="We use profile names, not passwords."
                               FontSize="12"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#1D4ED8, Dark=#BFD7FF}" />
                    </Border>
                </Grid>
            </Border>

            <VerticalStackLayout Spacing="10"
                                 IsVisible="{Binding HasExistingUsers}">
                <Label Text="Recent profiles"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#111827, Dark=White}" />
                <Label Text="Tap to continue quickly."
                       FontSize="13"
                       TextColor="{AppThemeBinding Light=#6B7280, Dark=#A1A9B5}" />
            </VerticalStackLayout>

            <Grid IsVisible="{Binding HasExistingUsers}">
                <CollectionView ItemsSource="{Binding ExistingUsers}"
                                SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="12" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                <Border Grid.Column="0"
                                        StrokeShape="RoundRectangle 20"
                                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#232932}"
                                        Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#404856}"
                                        Padding="8">
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                        <Border WidthRequest="48"
                                                HeightRequest="48"
                                                StrokeShape="RoundRectangle 24"
                                                BackgroundColor="{AppThemeBinding Light=#E0F2FE, Dark=#304866}"
                                                StrokeThickness="0">
                                            <Label Text="{Binding UserName, Converter={StaticResource UserInitialsConverter}}"
                                                   FontSize="16"
                                                   FontAttributes="Bold"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"
                                                   TextColor="{AppThemeBinding Light=#0369A1, Dark=#D8EAFE}" />
                                        </Border>

                                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                            <Label Text="{Binding UserName}"
                                                   FontSize="17"
                                                   FontAttributes="Bold"
                                                   TextColor="{AppThemeBinding Light=#111827, Dark=White}" />
                                        </VerticalStackLayout>

                                        <Label Grid.Column="2"
                                               Text="&#x203A;"
                                               FontSize="28"
                                               TextColor="{AppThemeBinding Light=#94A3B8, Dark=#7F8896}"
                                               VerticalOptions="Center"
                                               HorizontalOptions="End" />

                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type views:LoginPage}}, Path=BindingContext.UserTappedCommand}"
                                                                  CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>
                                    </Grid>
                                </Border>

                                <Border Grid.Column="1"
                                        WidthRequest="34"
                                        HeightRequest="34"
                                        StrokeShape="RoundRectangle 17"
                                        BackgroundColor="{AppThemeBinding Light=#FEF2F2, Dark=#3A2225}"
                                        Stroke="{AppThemeBinding Light=#FECACA, Dark=#7F1D1D}"
                                        StrokeThickness="1"
                                        VerticalOptions="Center"
                                        HorizontalOptions="End">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type views:LoginPage}}, Path=BindingContext.RemoveUserCommand}"
                                                              CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>
                                    <Label Text="&#x2212;"
                                           FontSize="22"
                                           FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light=#B91C1C, Dark=#FCA5A5}"
                                           HorizontalTextAlignment="Center"
                                           VerticalTextAlignment="Center" />
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>

            <ActivityIndicator IsVisible="{Binding IsLoading}"
                               IsRunning="{Binding IsLoading}"
                               Color="{AppThemeBinding Light=#2563EB, Dark=#60A5FA}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />

            <Border StrokeShape="RoundRectangle 24"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#20242B}"
                    Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#3A414C}"
                    Padding="18">
                    <VerticalStackLayout Spacing="12">
                        <VerticalStackLayout Spacing="4">
                        <Label Text="Create or continue"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#111827, Dark=White}" />
                        </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Enter a profile name"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#374151, Dark=#D2D8E2}" />
                        <Entry x:Name="UsernameEntry"
                               Placeholder="e.g. Khalid"
                               ReturnType="Done"
                               ClearButtonVisibility="WhileEditing"
                               BackgroundColor="{AppThemeBinding Light=#F9FAFB, Dark=#2A3038}"
                               TextColor="{AppThemeBinding Light=#111827, Dark=White}"
                               PlaceholderColor="{AppThemeBinding Light=#9CA3AF, Dark=#8A93A1}" />
                    </VerticalStackLayout>

                    <Button Text="Continue"
                            Clicked="OnLoginClicked"
                            BackgroundColor="{AppThemeBinding Light=#2563EB, Dark=#3B82F6}"
                            TextColor="White"
                            CornerRadius="16"
                            Padding="18,14" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
