<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="algoBhaiya.ReportBook.Presentation.Views.DatePickerPopup"
             BackgroundColor="#80000000"
             Padding="18">
    <Grid VerticalOptions="Center"
          HorizontalOptions="Center"
          RowDefinitions="Auto">
        <Border x:Name="CardBorder"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#111827}"
                Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#374151}"
                StrokeThickness="1"
                Padding="18"
                WidthRequest="340"
                MaximumWidthRequest="380">
            <VerticalStackLayout Spacing="14">
                <Grid ColumnDefinitions="Auto,*,Auto"
                      VerticalOptions="Center">
                    <Button Text="‹"
                            Clicked="OnPreviousMonthClicked"
                            WidthRequest="40"
                            HeightRequest="40"
                            CornerRadius="20"
                            Padding="0"
                            BackgroundColor="{AppThemeBinding Light=#F1F5F9, Dark=#1F2937}"
                            TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}" />

                    <VerticalStackLayout Grid.Column="1"
                                         Spacing="2"
                                         HorizontalOptions="Center"
                                         VerticalOptions="Center">
                        <Label Text="Select a date"
                               FontAttributes="Bold"
                               FontSize="18"
                               HorizontalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light=#0F172A, Dark=#F9FAFB}" />
                        <Label Text="{Binding MonthTitle}"
                               FontSize="13"
                               HorizontalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light=#64748B, Dark=#9CA3AF}" />
                    </VerticalStackLayout>

                    <Button Grid.Column="2"
                            Text="›"
                            Clicked="OnNextMonthClicked"
                            WidthRequest="40"
                            HeightRequest="40"
                            CornerRadius="20"
                            Padding="0"
                            BackgroundColor="{AppThemeBinding Light=#F1F5F9, Dark=#1F2937}"
                            TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}" />
                </Grid>

                <Grid x:Name="CalendarGrid"
                      ColumnSpacing="6"
                      RowSpacing="6" />

                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="10"
                      VerticalOptions="Center">
                    <HorizontalStackLayout Spacing="10"
                                           VerticalOptions="Center">
                        <Border x:Name="TodayChip"
                                WidthRequest="12"
                                HeightRequest="12"
                                StrokeThickness="0"
                                BackgroundColor="#2563EB" />
                        <Label Text="Today"
                               FontSize="12"
                               TextColor="{AppThemeBinding Light=#475569, Dark=#CBD5E1}" />

                        <Border x:Name="SelectedChip"
                                WidthRequest="12"
                                HeightRequest="12"
                                StrokeThickness="0"
                                BackgroundColor="#DCFCE7" />
                        <Label Text="Selected"
                               FontSize="12"
                               TextColor="{AppThemeBinding Light=#475569, Dark=#CBD5E1}" />
                    </HorizontalStackLayout>

                    <Button Grid.Column="1"
                            Text="Cancel"
                            Clicked="OnCancelClicked"
                            BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#1F2937}"
                            TextColor="{AppThemeBinding Light=#0F172A, Dark=#F9FAFB}"
                            CornerRadius="16"
                            Padding="14,10" />
                </Grid>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
